rules_version = '2';

// Regras do Firestore do DigitAI.
//
// Publique via:
//   firebase deploy --only firestore:rules
// ou cole no console: Firebase → Firestore → Rules.
//
// Modelo: admin root é quem tem email `digounet@gmail.com`. A partir dele
// outros admins podem ser cadastrados na coleção `admins/{uid}`. Códigos de
// desbloqueio são criados por admins e resgatados pelo próprio dono do email.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isRootAdmin() {
      return signedIn() && request.auth.token.email == 'digounet@gmail.com';
    }

    function isAdmin() {
      return isRootAdmin()
        || (signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Progresso do usuário: só o dono lê e escreve.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Ranking: qualquer um logado lê (jogo mostra a lista pra todos);
    // escrita do próprio score é permitida pra quem está logado.
    // Ajuste conforme seu modelo atual se já tiver algo mais restritivo.
    match /leaderboard/{docId} {
      allow read: if true;
      allow create, update: if signedIn();
    }

    // Interesses (formulário do Pro) — só escrever, não ler listagem.
    match /interests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admins: ninguém vê a lista a não ser os próprios admins.
    // Root é admin implícito; outros precisam ter doc aqui.
    match /admins/{uid} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Códigos de desbloqueio.
    //  - Admin pode criar, listar, apagar.
    //  - Usuário comum pode ler APENAS o código específico cujo email bate
    //    com o dele (necessário pro fluxo de resgate), e só pode atualizá-lo
    //    uma única vez, escrevendo os campos `usedAt`, `usedByUid`,
    //    `usedByEmail`, e apenas se ainda não foi usado.
    match /unlockCodes/{code} {
      allow read: if isAdmin()
        || (signedIn()
            && resource.data.email == request.auth.token.email);

      allow create, delete: if isAdmin();

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.email == request.auth.token.email
          && resource.data.usedAt == null
          && request.resource.data.usedByUid == request.auth.uid
          && request.resource.data.usedByEmail == request.auth.token.email
          && request.resource.data.email == resource.data.email
          && request.resource.data.difficulty == resource.data.difficulty
          && request.resource.data.levelIds == resource.data.levelIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdByEmail == resource.data.createdByEmail
          && request.resource.data.createdAt == resource.data.createdAt
        );
    }
  }
}
